{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Todo Schema v3.1",
  "description": "Schema for validating todo.md frontmatter generated by skill-planner",
  "type": "object",
  "required": [
    "skill_schema_version",
    "artifact_type",
    "skill_name",
    "generated_by",
    "generated_at",
    "stage",
    "status",
    "phases",
    "blockers",
    "prerequisites",
    "handoff"
  ],
  "properties": {
    "skill_schema_version": {
      "type": "string",
      "enum": ["3.0.0", "3.1.0"],
      "description": "Schema version"
    },
    "artifact_type": {
      "type": "string",
      "enum": ["todo"],
      "description": "Type of artifact"
    },
    "skill_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      "description": "Kebab-case skill name"
    },
    "generated_by": {
      "type": "string",
      "enum": ["skill-planner"],
      "description": "Generator skill"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "stage": {
      "type": "string",
      "enum": ["planner"],
      "description": "Pipeline stage"
    },
    "status": {
      "type": "string",
      "enum": ["in_progress", "ready_for_builder", "blocked"],
      "description": "Todo status"
    },
    "trace_to_design": {
      "type": "string",
      "description": "Path to design.md"
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/phase"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/blocker"
      }
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/prerequisite"
      }
    },
    "handoff": {
      "type": "object",
      "required": ["next_stage", "ready_condition"],
      "properties": {
        "next_stage": {
          "type": "string",
          "enum": ["builder"]
        },
        "ready_condition": {
          "type": "object",
          "required": ["required"],
          "properties": {
            "required": {
              "type": "object",
              "properties": {
                "blockers_empty": { "type": "boolean" },
                "phase0_done": { "type": "boolean" },
                "prerequisites_ready": { "type": "boolean" },
                "schema_valid": { "type": "boolean" },
                "design_zones_covered": { "type": "boolean" }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "phase": {
      "type": "object",
      "required": ["id", "name", "tasks"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^PH[0-9]+$"
        },
        "name": {
          "type": "string"
        },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/task"
          }
        }
      }
    },
    "task": {
      "type": "object",
      "required": ["id", "title", "zone", "priority", "trace", "status"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^T[0-9]+\\.[0-9]+$"
        },
        "title": {
          "type": "string"
        },
        "zone": {
          "type": "string",
          "enum": ["core", "knowledge", "scripts", "templates", "data", "loop", "assets"]
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "trace": {
          "type": "string",
          "pattern": "^\\[(TỪ DESIGN §[0-9]+(\\.[0-9]+)?|GỢI Ý BỔ SUNG|TỪ AUDIT TÀI NGUYÊN|CẦN LÀM RÕ)\\]"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^T[0-9]+\\.[0-9]+$"
          }
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "done", "skipped"]
        },
        "file_target": {
          "type": "string"
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "blocker": {
      "type": "object",
      "required": ["id", "type", "description", "resolved"],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["CLARIFICATION_NEEDED", "DESIGN_CONFLICT", "RESOURCE_MISSING"]
        },
        "description": {
          "type": "string"
        },
        "resolved": {
          "type": "boolean"
        }
      }
    },
    "prerequisite": {
      "type": "object",
      "required": ["item", "tier", "status"],
      "properties": {
        "item": {
          "type": "string"
        },
        "tier": {
          "type": "string",
          "enum": ["domain", "technical", "packaging"]
        },
        "status": {
          "type": "string",
          "enum": ["ready", "missing", "thin"]
        },
        "resource_file": {
          "type": "string"
        },
        "action_if_missing": {
          "type": "string"
        }
      }
    }
  }
}

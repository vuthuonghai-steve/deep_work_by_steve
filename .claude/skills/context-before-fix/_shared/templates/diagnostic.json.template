{
  "$schema": "../schemas/diagnostic.schema.json",
  "metadata": {
    "skill_name": "{skill_name}",
    "version": "{version}",
    "diagnostic_timestamp": "{timestamp}",
    "origin_stage": "stage_4_tester",
    "target_stage": "stage_3_builder"
  },
  "failure_summary": {
    "confidence_score": {confidence_score},
    "primary_cause": "Logic Error"
  },
  "detailed_diagnostics": [
    {
      "failed_test_case_id": "TC-001",
      "error_category": "LogicError",
      "target_file": "scripts/action-target.py",
      "line_number": 42,
      "error_log": "AssertionError: Expected {expected} but got {actual}",
      "suggested_mitigation": "Ensure the output is stripped of whitespace before assertion check"
    }
  ]
}

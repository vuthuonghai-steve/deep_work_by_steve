{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Context Sources Schema",
  "description": "Schema for context-sources.json in Heavy Thinking Manual output",
  "version": "1.0.0",
  "type": "object",
  "required": ["audit_timestamp", "sources", "audit_summary"],
  "properties": {
    "audit_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of context audit"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z]+-[a-z0-9]+$"
    },
    "sources": {
      "type": "object",
      "properties": {
        "hermes_memory": {
          "$ref": "#/definitions/memory_source"
        },
        "session_history": {
          "$ref": "#/definitions/session_source"
        },
        "project_files": {
          "$ref": "#/definitions/project_source"
        }
      },
      "required": ["hermes_memory", "session_history", "project_files"]
    },
    "audit_summary": {
      "type": "object",
      "properties": {
        "total_sources": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "loaded": {
          "type": "integer"
        },
        "partial": {
          "type": "integer"
        },
        "unavailable": {
          "type": "integer"
        },
        "missing_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "total_size_bytes": {
          "type": "integer"
        }
      }
    },
    "gap_analysis": {
      "type": "object",
      "properties": {
        "user_preferences": {
          "type": "string",
          "enum": ["current", "partial", "stale", "unavailable"]
        },
        "project_context": {
          "type": "string",
          "enum": ["complete", "partial", "minimal", "unavailable"]
        },
        "session_continuity": {
          "type": "string",
          "enum": ["complete", "partial", "broken"]
        }
      }
    },
    "enriched_context": {
      "type": "object",
      "description": "Enriched context with temporal, spatial, semantic annotations",
      "properties": {
        "temporal": {
          "type": "object",
          "properties": {
            "created": {
              "type": "string",
              "format": "date-time"
            },
            "modified": {
              "type": "string",
              "format": "date-time"
            },
            "age_days": {
              "type": "integer"
            }
          }
        },
        "spatial": {
          "type": "object",
          "properties": {
            "workspace": {
              "type": "string"
            },
            "paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "semantic": {
          "type": "object",
          "properties": {
            "domain": {
              "type": "string"
            },
            "entities": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "relationships": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "memory_source": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["loaded", "partial", "unavailable"]
        },
        "loaded_at": {
          "type": "string",
          "format": "date-time"
        },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["user_profile", "project_context", "convention", "tool_config"]
              },
              "content": {
                "type": "string"
              },
              "age_days": {
                "type": "integer"
              },
              "verified": {
                "type": "boolean"
              }
            }
          }
        },
        "size_bytes": {
          "type": "integer"
        },
        "stale_entries": {
          "type": "integer"
        }
      }
    },
    "session_source": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["loaded", "partial", "unavailable"]
        },
        "loaded_at": {
          "type": "string",
          "format": "date-time"
        },
        "session_id": {
          "type": "string"
        },
        "recent_messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": {
                "type": "string",
                "enum": ["user", "assistant", "system"]
              },
              "content": {
                "type": "string"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        },
        "pending_tasks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recent_corrections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "continuation_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "size_bytes": {
          "type": "integer"
        }
      }
    },
    "project_source": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["loaded", "partial", "unavailable"]
        },
        "loaded_at": {
          "type": "string",
          "format": "date-time"
        },
        "workspace": {
          "type": "string"
        },
        "files_loaded": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              },
              "size_bytes": {
                "type": "integer"
              },
              "type": {
                "type": "string",
                "enum": ["guidelines", "source", "config", "documentation", "test"]
              },
              "loaded": {
                "type": "boolean"
              },
              "truncated": {
                "type": "boolean"
              }
            }
          }
        },
        "guidelines_found": {
          "type": "object",
          "properties": {
            "coding_standards": {
              "type": "boolean"
            },
            "architecture_patterns": {
              "type": "boolean"
            },
            "naming_conventions": {
              "type": "boolean"
            }
          }
        },
        "size_bytes": {
          "type": "integer"
        },
        "truncated_files": {
          "type": "integer"
        }
      }
    }
  }
}

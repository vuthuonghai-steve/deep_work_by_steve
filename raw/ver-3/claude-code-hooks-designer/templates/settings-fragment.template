{
  "hooks": {
    "{{event_name}}": [
      {
        "matcher": "{{matcher_raw}}",
        "hooks": [
          {
            "type": "{{handler_type}}",
            {{#if_eq handler_type "command"}}
            "command": "{{handler_command_or_script}}",
            {{/if_eq}}
            {{#if_eq handler_type "prompt"}}
            "prompt": "{{handler_prompt}}",
            "model": "{{handler_model}}",
            {{/if_eq}}
            {{#if_eq handler_type "agent"}}
            "prompt": "{{handler_prompt}}",
            {{/if_eq}}
            "timeout": {{timeout_seconds}},
            {{#if continueOnBlock}}
            "continueOnBlock": true,
            {{/if}}
            {{#if if_condition}}
            "if": "{{if_condition}}",
            {{/if}}
            "description": "{{handler_description}}"
          }
        ]
      }
    ]
  }
}

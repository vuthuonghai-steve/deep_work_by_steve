{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DAG Plan Schema",
  "description": "Schema xác thực cho tệp kế hoạch công việc dag_plan.json thuộc Stage 2 (Planner)",
  "type": "object",
  "required": ["$schema", "metadata", "tasks"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "metadata": {
      "type": "object",
      "required": ["skill_name", "version", "planner_timestamp"],
      "additionalProperties": false,
      "properties": {
        "skill_name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "planner_timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["task_id", "name", "description", "dependencies", "target_file", "trace_tag", "estimated_hours"],
        "additionalProperties": false,
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^TSK-[0-9]+$"
          },
          "name": {
            "type": "string",
            "minLength": 5
          },
          "description": {
            "type": "string",
            "minLength": 15
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^TSK-[0-9]+$"
            }
          },
          "target_file": {
            "type": "string"
          },
          "trace_tag": {
            "type": "string",
            "pattern": "^\\[TỪ (DESIGN|AUDIT TÀI NGUYÊN) §.+\\]$"
          },
          "estimated_hours": {
            "type": "number",
            "minimum": 0.1
          }
        }
      }
    }
  }
}

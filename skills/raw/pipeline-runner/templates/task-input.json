{
  "task_id": "task-{stage_id}",
  "stage_id": "{stage_id}",
  "skill_name": "{skill_name}",
  "skill_path": "{skill_path}",

  // Pipeline Awareness Context (NEW - Phase 4)
  "pipeline_context": {
    "pipeline_id": "{pipeline_id}",
    "pipeline_name": "{pipeline_name}",
    "current_stage_index": {current_stage_index},
    "total_stages": {total_stages},
    "stage_percentage": "{stage_percentage}",
    "predecessors": [
      {
        "stage_id": "{pred_stage_id}",
        "skill": "{pred_skill_name}",
        "output_dir": "{pred_output_dir}"
      }
    ],
    "global_context": {
      "project": "{project}",
      "input_base": "{input_base}",
      "output_base": "{output_base}"
    }
  },

  "input": {
    "project": "{project}",
    "source_docs": [
      "{input_doc_1}",
      "{input_doc_2}"
    ]
  },
  "output": {
    "target_dir": "{output_dir}",
    "index_file": "{index_file}"
  },
  "validation": {
    "script": "{validation_script}",
    "expected_exit_code": 0,
    "required_outputs": [
      "{output_1}",
      "{output_2}"
    ]
  },
  "handoff": {
    "from_stage": "{previous_stage_id}",
    "previous_output": "{previous_output_path}"
  }
}

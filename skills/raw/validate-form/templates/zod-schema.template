# Zod Schema Template

## Basic Schema Template

```typescript
// {{collectionName}}.ts - {{description}}

import { z } from "zod"

// ============================================================================
// {{collectionName | capitalize}} VALIDATION
// ============================================================================

export const {{collectionName}}Schema = z.object({
  {{#fields}}
  {{name}}: {{validator}}{{#if required}}.{{/if}}{{#unless required}}.optional(){{/unless}},
  {{/fields}}
})

export type {{collectionName | capitalize}}FormData = z.infer<typeof {{collectionName}}Schema>
```

## Example Output

### Input
- Collection: `products`
- Fields: name (text, required), price (number, required), description (textarea, optional)

### Output

```typescript
// products.ts - Product validation

import { z } from "zod"

// ============================================================================
// PRODUCT VALIDATION
// ============================================================================

export const productSchema = z.object({
  name: z.string()
    .min(1, "Tên sản phẩm là bắt buộc")
    .max(100, "Tên sản phẩm không được quá 100 ký tự"),
  price: z.number()
    .min(0, "Giá sản phẩm không được âm"),
  description: z.string().optional(),
})

export type ProductFormData = z.infer<typeof productSchema>
```

## Field Type Patterns

### Text Field
```typescript
{{name}}: z.string()
  .min({{min}}{{#if message}}, "{{message}}"{{/if}})
  .max({{max}}{{#if message}}, "{{message}}"{{/if}})
```

### Number Field
```typescript
{{name}}: z.number()
  .min({{min}}{{#if message}}, "{{message}}"{{/if}})
  .max({{max}}{{#if message}}, "{{message}}"{{/if}})
```

### Email Field
```typescript
{{name}}: z.string()
  .email("{{message}}")
```

### Select Field
```typescript
{{name}}: z.enum([{{#options}}'{{this}}'{{#unless @last}}, {{/unless}}{{/options}}], {
  errorMap: () => ({ message: "{{message}}" })
})
```

### Relationship Field
```typescript
{{name}}: z.string()
  .min(1, "{{message}}")
```

### Array Field
```typescript
{{name}}: z.array(z.string())
  .min({{min}}{{#if message}}, "{{message}}"{{/if}})
  .max({{max}}{{#if message}}, "{{message}}"{{/if}})
```

## Conditional Validation

### Password Confirmation
```typescript
export const registerSchema = z.object({
  email: z.string().email("Email không hợp lệ"),
  password: z.string().min(8, "Mật khẩu phải có ít nhất 8 ký tự"),
  confirmPassword: z.string(),
}).refine(data => data.password === data.confirmPassword, {
  message: "Mật khẩu không khớp",
  path: ["confirmPassword"],
})
```

### Custom Validation
```typescript
export const orderSchema = z.object({
  orderDate: z.string(),
  deliveryDate: z.string(),
}).refine(data => new Date(data.deliveryDate) > new Date(data.orderDate), {
  message: "Ngày giao hàng phải sau ngày đặt hàng",
  path: ["deliveryDate"],
})
```
